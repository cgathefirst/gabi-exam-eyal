properties([
    parameters([
        choice(
            name: 'TARGET_SUBFOLDER', 
            choices: ['dev', 'qa', 'prod'], 
            description: 'Select the target environment folder'
        )
    ])
])

def appname = "examgabieyal"
def repo = "cgabya12"  
def apptag = "${env.BUILD_NUMBER}"
def appimage = "docker.io/${repo}/${appname}:${apptag}"
def targetGitRepo    = "https://github.com/cgathefirst/gitops-argo.git" 
def targetBranch     = "second"
def targetFolder     = "app1" 
def gitCredentialsId = "github-token-push"


podTemplate(cloud: 'kubernetes', containers: [
    containerTemplate(
        name: 'jnlp', 
        image: 'jenkins/inbound-agent:latest'
    ),
    containerTemplate(
        name: 'docker', 
        image: 'docker:26-dind', 
        privileged: true,      
        args: '--storage-driver=overlay2' 
    ),
    containerTemplate(
        name: 'helm',
        image: 'alpine/helm:3.14.0',
        command: 'sleep',
        args: '99d'
    )
], 
volumes: [
    emptyDirVolume(mountPath: '/var/lib/docker', memory: false) 
]) {
    
    node(POD_LABEL) {
        stage('Checkout') { 
            container('jnlp') {
                sh '/usr/bin/git config --global http.sslVerify false'
                checkout scm
            }
        } 
        
        stage('Security and Linting') {
            parallel(
                'Linting': {
                    container('docker') {
                        echo " now using Flake8 "
                    }
                },
                'Security': {
                    container('docker') {
                        echo "Now using Trivy for Docker"
                    }
                }
            )
        }
        
        stage('Docker Build & Push') {
            container('docker') {
                sh "docker build -t ${appimage} ."
                withCredentials([usernamePassword(credentialsId: 'jenkins-dockcred', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_TOKEN')]) {
                    sh "echo \$DOCKER_TOKEN | docker login -u \$DOCKER_USER --password-stdin"
                    sh "docker push ${appimage}"            
                }
            }
        }

        stage('Helm Template Validation') {
            container('helm') {
                sh "helm template ${appname}-${apptag} ./helmcharts > pipeapp.yaml && cat pipeapp.yaml"
                sh "ls -la"
            }
        }

stage('Git Push Manifest') {
            container('jnlp') {
                // Combine the base folder (app1) with the user choice (dev/qa/prod)
                def destinationPath = "${targetFolder}/${params.TARGET_SUBFOLDER}"
                echo "Target destination directory inside repository will be: ${destinationPath}"
                withCredentials([usernamePassword(credentialsId: gitCredentialsId, usernameVariable: 'GIT_USER', passwordVariable: 'GIT_TOKEN')]) {
                    sh """
                        git config --global user.email "jenkinsbot@gabi.com"
                        git config --global user.name "Jenkins CI"
                        git config --global http.sslVerify false
                        rm -rf target-git-repo
                        git clone --branch ${targetBranch} https://\$GIT_USER:\$GIT_TOKEN@${targetGitRepo} target-git-repo
                        mkdir -p target-git-repo/${destinationPath}
                        cp pipeapp.yaml target-git-repo/${destinationPath}/pipeapp.yaml
                        cd target-git-repo
                        git add ${destinationPath}/pipeapp.yaml
                        if ! git diff-index --quiet HEAD --; then
                            git commit -m "Automated deployment update to ${destinationPath}: ${appname} tag ${apptag}"
                            git push origin ${targetBranch}
                        else
                            echo "No changes detected in the manifest. Skipping push."
                        fi
                    """
                }
            }
        }
    }
}
