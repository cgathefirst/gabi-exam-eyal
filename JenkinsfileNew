properties([
    parameters([
        // 1. Fixed Choice Parameter using explicit map notation
        [
            $class: 'ChoiceParameterDefinition',
            name: 'TARGET_BRANCH', 
            choices: "main\nsecond\ntest", 
            description: 'Select the remote Git branch you want to push the helmtemplate.yaml to.'
        ],
        
        // 2. Active Choices Parameter configuration
        [
            $class: 'ChoiceParameter',
            choiceType: 'PT_SINGLE_SELECT',
            description: 'Select the target folder within the repository to place the template.',
            name: 'TARGET_FOLDER',
            script: [
                $class: 'GroovyScript',
                fallbackScript: [
                    classpath: [],
                    sandbox: true,
                    script: "return ['error-loading-folders']"
                ],
                script: [
                    classpath: [],
                    sandbox: true,
                    script: """
                        def repoUrl = "https://github.com/cgathefirst/gitops-argo.git" 
                        def proc = ['sh', '-c', "git ls-remote --exit-code \${repoUrl} &>/dev/null && git ls-tree -r --name-only HEAD:${params.TARGET_BRANCH} | grep '/' | awk -F/ '{print \$1}' | sort -u || echo 'root_only'"].execute()
                        proc.waitFor()
                        
                        def folders = proc.in.text.readLines()
                        folders.add(0, ".") 
                        return folders
                    """
                ]
            ]
        ]
    ])
])

def appname = "examgabieyal"
def repo = "cgabya12"  // Your DockerHub username
def apptag = "${env.BUILD_NUMBER}"
def appimage = "docker.io/${repo}/${appname}:${apptag}"

podTemplate(cloud: 'kubernetes', containers: [
    containerTemplate(
        name: 'jnlp', 
        image: 'jenkins/inbound-agent:latest'
    ),
    containerTemplate(
        name: 'docker', 
        image: 'docker:26-dind', 
        privileged: true,      
        args: '--storage-driver=overlay2' 
    ),
    containerTemplate(
        name: 'helm',
        image: 'alpine/helm:3.14.0',
        command: 'sleep',
        args: '99d'
    )
], 
volumes: [
    emptyDirVolume(mountPath: '/var/lib/docker', memory: false) 
]) {
    
    node(POD_LABEL) {
        stage('Checkout') { 
            container('jnlp') {
                sh '/usr/bin/git config --global http.sslVerify false'
                checkout scm
            }
        } 
        
        stage('Security and Linting') {
            parallel(
                'Linting': {
                    container('docker') {
                        echo " now using Flake8 for "
                    }
                },
                'Security': {
                    container('docker') {
                        echo "Now using Trivy for Docker"
                    }
                }
            )
        }

        stage('Docker Build & Push') {
            container('docker') {
                sh "docker build -t ${appimage} ."
                
                withCredentials([usernamePassword(credentialsId: 'jenkins-dockcred', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_TOKEN')]) {
                    sh "echo \$DOCKER_TOKEN | docker login -u \$DOCKER_USER --password-stdin"
                    sh "docker push ${appimage}"            
                }
            }
        }

        stage('Helm Template Validation') {
            container('helm') {
                sh "helm template ${appname}-${apptag} ./helmcharts > helmtemplate.yaml"
            }
        }
        
